# AWS Configuration for S3 Download URLs
# Copy this file to .env and replace with your actual values

AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key_id_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key_here
S3_BUCKET=your_s3_bucket_name_here
CLOUDFRONT_DOMAIN=your_cloudfront_domain_here

# SurrealDB Configuration
SURREALDB_URL=wss://your-instance.surreal.cloud
SURREALDB_NS=your_namespace
SURREALDB_DB=your_database
SURREALDB_USERNAME=your_username
SURREALDB_PASSWORD=your_password

# SurrealDB Client-Side (Vite) Configuration
# These are exposed to the client and must have VITE_ prefix
VITE_SURREALDB_URL=wss://your-instance.surreal.cloud
VITE_SURREALDB_NS=your_namespace
VITE_SURREALDB_DB=your_database
